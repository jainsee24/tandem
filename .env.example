PASSWORD=change-me
PORT=8080
# HEADLESS=0 (default): run Chrome headful inside an auto-started Xvfb display.
# This avoids bot detection (clean User-Agent + real WebGL). Set 1 for the old
# headless mode (faster, but many sites flag it as a bot).
HEADLESS=0
XVFB_DISPLAY=:99
# Hard cap per agent task, in minutes. Agentic browsing (multi-step forms,
# research, comparisons) can run long, so this is generous by default.
TASK_TIMEOUT_MIN=180
CHROME_BIN=/snap/bin/chromium
# Screencast JPEG quality (1-100). Lower = smaller frames = smoother over a slow
# tunnel; higher = sharper. Frame rate is render-bound, not quality-bound.
SCREENCAST_QUALITY=60
